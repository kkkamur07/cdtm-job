# Next.js / browser — copy to `frontend/.env.local` (gitignored).
# Never put SUPABASE_SERVICE_ROLE_KEY or other server secrets here.

# FastAPI base URL (no trailing slash). Must match CORS on the backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# API routes use prefix /api/v1 (baked into openapi.json — regenerate after backend changes).

# Optional: public Supabase anon key only if the browser talks to Supabase directly.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
