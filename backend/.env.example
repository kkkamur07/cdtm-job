# Backend-only environment (FastAPI, integration tests, scripts).
# Copy to `backend/.env` (gitignored). Do not commit secrets.
#
# Optional: use a file elsewhere instead of the default path:
# BACKEND_ENV_FILE=/absolute/path/.env

# Project URL: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service role: Dashboard → Settings → API → service_role
# SERVER ONLY — never put in frontend/.env* or NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: anon key (only if the Python backend needs RLS-scoped reads as anon)
# SUPABASE_ANON_KEY=your-anon-key

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Versioned REST base path (companies/jobs/seekers mount here).
API_ROUTE_PREFIX=/api/v1

# Comma-separated origins for CORS (Next dev — localhost and 127.0.0.1 differ for CORS)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# local | staging | production
APP_ENV=local

# --- Supabase CLI (local dev / CI push to remote) --------------------------
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=
