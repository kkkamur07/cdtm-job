# Optional: absolute path to a dotenv file (skips default repo-root .env resolution).
# BACKEND_ENV_FILE=/absolute/path/.env

# Project URL: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service role: Dashboard → Settings → API → service_role
# SERVER ONLY — FastAPI (`backend/`) loads this from repo-root `.env`.
# NEVER put this in `frontend/.env*` and NEVER use a `NEXT_PUBLIC_*` name (browser bundles those).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: anon key (only if the Python backend needs RLS-scoped reads as anon)
# SUPABASE_ANON_KEY=your-anon-key

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Versioned REST base path (companies/jobs/seekers mount here). Change to /api/v2 when you ship a new API surface.
API_ROUTE_PREFIX=/api/v1

# Comma-separated origins for CORS (include Next dev server)
CORS_ORIGINS=http://localhost:3000

# local | staging | production (log/metrics labels, dummy/demo toggles — not a security gate)
APP_ENV=local

# --- Supabase CLI (local dev / CI push to remote) --------------------------
# Personal access token for `supabase link` / CI (do NOT put in frontend)
# https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=

# Linked project ref (shown in Dashboard URL); used after `supabase link`
# SUPABASE_PROJECT_REF=

# =============================================================================
# Browser / Next.js: use ONLY the anon key with NEXT_PUBLIC_* in frontend/.env.local
# (see frontend/.env.example). Never duplicate SUPABASE_SERVICE_ROLE_KEY there.
# =============================================================================
